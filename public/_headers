# Cloudflare headers. Security and caching.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  # Content-Security-Policy is emitted per-page by Astro (build.experimental.csp)
  # with SHA-256 hashes for every inline script and style.

# Hashed Astro assets are immutable.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts, long-lived.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Generated OG images, long-lived.
/og/*
  Cache-Control: public, max-age=31536000, immutable

# Legacy pack + brand book: header-based CSP (these pages have no meta CSP).
/3d-process/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'

/brand-guidelines/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'

/book/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'

/book/assets/*
  Cache-Control: public, max-age=31536000, immutable

/brand-guidelines/vendor/*
  Cache-Control: public, max-age=31536000, immutable
