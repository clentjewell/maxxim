# Cloudflare headers. Security and caching.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # Content-Security-Policy is emitted per-page by Astro (build.experimental.csp)
  # with SHA-256 hashes for every inline script and style.

# Hashed Astro assets are immutable.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts, long-lived.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Generated OG images, long-lived.
/og/*
  Cache-Control: public, max-age=31536000, immutable

# Legacy sub-sites get a static CSP (the Astro pages carry per-page hashed CSP meta).
/book/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
/3d-process/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://assets.maxxim.ai; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
