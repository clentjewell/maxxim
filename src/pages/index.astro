---
import { getCollection } from "astro:content";
import { SITE, SPECIALISTS } from "@lib/site";
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Button from "@components/ui/Button.astro";
import CaseCard from "@components/ui/CaseCard.astro";
import Monogram from "@components/ui/Monogram.astro";
import FrameDashboard from "@components/frames/FrameDashboard.astro";
import FrameClientRoom from "@components/frames/FrameClientRoom.astro";
import FrameBrain from "@components/frames/FrameBrain.astro";

const all = await getCollection("work", ({ data }) => !data.draft);
const marquee = all
  .sort((a, b) => (a.data.marquee === b.data.marquee ? a.data.order - b.data.order : a.data.marquee ? -1 : 1))
  .slice(0, 3);

const values = [
  { n: "01", t: "Fast", p: "AI runs the repeatable volume at speed. No agency drag." },
  { n: "02", t: "Accountable", p: "A named human signs off every gate. Every output carries a person." },
  { n: "03", t: "Method-backed", p: "A proven, gated process — not a prompt and a prayer." },
];
---

<BaseLayout title="Home">
  <!-- HERO -->
  <section class="hero">
    <picture class="hero-bg" aria-hidden="true">
      <source srcset="/images/cover-city.webp" type="image/webp" />
      <img
        src="/images/cover-city.jpg"
        width="2048"
        height="1152"
        alt=""
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="container hero-copy" data-reveal>
      <p class="eyebrow">AI-powered · Human-approved</p>
      <h1>A whole agency, <em>in a box</em>.</h1>
      <p class="lede">Maxxim is a complete marketing agency in a box. AI does the work of a full agency, strategy, brand, website, content and campaigns, and a named human signs off every piece before it ships.</p>
      <div class="hero-actions">
        <Button href="/work">See the work</Button>
        <Button href="/method" variant="solid-invert">How it works</Button>
      </div>
    </div>
    <span class="wm"><Monogram size={20} /> Maxxim</span>
  </section>

  <!-- WHAT YOU GET -->
  <Section rule>
    <div class="get-head" data-reveal>
      <p class="eyebrow">What you get</p>
      <h2>The work of a full agency, delivered as finished assets you own.</h2>
    </div>
    <div class="gets">
      {[
        { n: "01", t: "Strategy", p: "Positioning and a plan you can act on." },
        { n: "02", t: "Brand", p: "Identity, voice and guidelines, locked." },
        { n: "03", t: "Website", p: "Launched live on your own domain." },
        { n: "04", t: "Content", p: "Written, designed and scheduled." },
        { n: "05", t: "Campaigns", p: "Run, measured and refined." },
      ].map((g) => (
        <div class="get lift" data-reveal>
          <span class="gn">{g.n}</span>
          <h3>{g.t}</h3>
          <p>{g.p}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- THE WHY -->
  <Section tone="mist">
    <div class="why" data-reveal>
      <p class="eyebrow">The trust gap</p>
      <h2>Agencies are human but slow. AI tools are fast but unaccountable.</h2>
      <p class="measure why-sub">Maxxim is built to be both at once, so the work arrives fast, accountable and finished.</p>
    </div>
    <div class="values">
      {values.map((v) => (
        <div class="value lift" data-reveal>
          <span class="vn">{v.n}</span>
          <h3>{v.t}</h3>
          <p>{v.p}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- THE SEAM 80/20 -->
  <Section>
    <div class="seam" data-reveal>
      <p class="eyebrow">The seam</p>
      <h2>AI runs the repeatable 80%. The human owns the 20% clients pay for.</h2>
      <div class="seam-bar" role="img" aria-label="Twenty percent human, eighty percent machine, human-checked at every gate">
        <div class="human"><span class="pct">20%</span><span class="lbl">Human · trust, taste, judgement</span></div>
        <div class="machine"><span class="pct">80%</span><span class="lbl">Machine · the repeatable volume, checked at every gate</span></div>
      </div>
      <p class="measure seam-note">Human in the loop is the point, not a limitation. No phase moves until a named person has signed it off.</p>
    </div>
  </Section>

  <!-- THE METHOD -->
  <Section tone="ink">
    <div class="method-head" data-reveal>
      <p class="eyebrow">The method</p>
      <h2>3D <span class="plus">+</span> Deepen</h2>
      <p class="measure">Discover, Design, Deploy, then the Deepen loop once the engine is live. Each phase is gated: nothing proceeds until a named human signs it off.</p>
    </div>
    <div class="phases">
      {[
        { no: "01", t: "Discover", d: "Always human. Context, audience, the real problem — mapped before a pixel is drawn." },
        { no: "02", t: "Design", d: "Strategy, positioning, identity and assets — signed off at the gate." },
        { no: "03", t: "Deploy", d: "Live work, owned by the client, on their own domain." },
        { no: "04", t: "Deepen", d: "The compounding loop that keeps the engine sharp." },
      ].map((p) => (
        <div class="phase" data-reveal>
          <span class="pno">{p.no}</span>
          <h3>{p.t}</h3>
          <p>{p.d}</p>
        </div>
      ))}
    </div>
    <div class="method-cta" data-reveal>
      <Button href="/method" variant="solid-invert">Walk the method</Button>
    </div>
  </Section>

  <!-- INSIDE MAXXIM -->
  <Section rule>
    <div class="inside-head" data-reveal>
      <p class="eyebrow">Inside Maxxim</p>
      <h2>The whole agency, on one screen.</h2>
      <p class="measure">Every client, every deliverable and every approval in one place: the operator dashboard, the client room, and the Brain.</p>
    </div>
    <div class="frames">
      <figure class="frame lift-frame" data-reveal>
        <FrameDashboard />
        <figcaption>The morning view: every client, live progress and AI spend — one screen, no status meetings.</figcaption>
      </figure>

      <figure class="frame lift-frame" data-reveal>
        <FrameClientRoom />
        <figcaption>One room per client: onboarding, the 3D Process at 26/26, brand, website, studios, Brain and files.</figcaption>
      </figure>

      <figure class="frame lift-frame" data-reveal>
        <FrameBrain />
        <figcaption>Ask Ari anything about this client — grounded in every document their engagement has produced.</figcaption>
      </figure>
    </div>
    <p class="frames-note">Frames recreated from the live Maxxim dashboard.</p>
  </Section>

  <!-- SPECIALISTS -->
  <Section tone="mist">
    <div class="spec-head" data-reveal>
      <p class="eyebrow">The method, made visible</p>
      <h2>Four named specialists.</h2>
    </div>
    <div class="specs">
      {SPECIALISTS.map((s) => (
        <div class="spec lift" data-reveal>
          <span class="spec-mono"><Monogram size={22} /></span>
          <div class="spec-name">{s.name}</div>
          <div class="spec-role">{s.role}</div>
          <p class="spec-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- BRAIN -->
  <section class="brain-band">
    <picture class="brain-bg" aria-hidden="true">
      <source srcset="/images/mx-brain.webp" type="image/webp" />
      <img
        src="/images/mx-brain.jpg"
        alt=""
        aria-hidden="true"
        width="1376"
        height="768"
        loading="lazy"
        decoding="async"
      />
    </picture>
    <div class="brain-scrim" aria-hidden="true"></div>
    <div class="container brain-copy" data-reveal>
      <p class="eyebrow">The Brain</p>
      <h2>Every client gets a Brain.</h2>
      <p class="measure">Ari is an assistant grounded only in that client's documents — nothing generic, nothing borrowed. Ask a question, get an answer with the full engagement behind it. Anything worth keeping lands in their Files. Clients get Ari in their portal; the team gets the same context in Cowork.</p>
      <p class="brain-support">The Brain holds everything. The human at the wheel decides what it's for.</p>
    </div>
  </section>

  <!-- WORK -->
  <Section rule>
    <div class="work-head" data-reveal>
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>Finished, owned outcomes.</h2>
      </div>
      <Button href="/work" variant="ghost">All work</Button>
    </div>
    <div class="work-grid">
      {marquee.map((c) => (
        <CaseCard
          slug={c.id}
          client={c.data.client}
          summary={c.data.summary}
          category={c.data.category}
          metric={c.data.results[0]?.metric}
          metricLabel={c.data.results[0]?.label}
          status={c.data.status}
        />
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <section class="cta-band">
    <picture class="cta-bg" aria-hidden="true">
      <source srcset="/images/mx-wheel.webp" type="image/webp" />
      <img src="/images/mx-wheel.jpg" alt="" loading="lazy" decoding="async" />
    </picture>
    <div class="container cta-copy" data-reveal>
      <h2>The whole agency, in a box, with a human at the wheel.</h2>
      <p class="measure">Strategy to campaigns, done at AI speed and signed off by a named person. Yours from day one.</p>
      <div class="final-actions">
        <Button href="/contact" variant="solid-invert">Start a conversation</Button>
        <Button href="/powered-by" variant="ghost">Powered by Maxxim</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: min(88vh, 860px);
    background: var(--color-ink);
  }
  .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; overflow: hidden; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (prefers-reduced-motion: no-preference) {
    .hero-bg img { animation: mx-kenburns 22s var(--ease-out-quiet) forwards; }
    @keyframes mx-kenburns {
      from { transform: scale(1); }
      to { transform: scale(1.07); }
    }
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-ink) 88%, transparent) 0%, color-mix(in srgb, var(--color-ink) 62%, transparent) 55%, color-mix(in srgb, var(--color-ink) 30%, transparent) 100%);
  }
  .hero-scrim::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, var(--color-ink), transparent 30%);
  }
  .hero-copy {
    position: relative;
    z-index: 1;
    padding-block: clamp(48px, 8vh, 96px) clamp(40px, 6vw, 72px);
  }
  .hero-copy .eyebrow { color: var(--color-blue-tint); }
  h1 {
    font-size: var(--text-display);
    line-height: var(--text-display--line-height);
    margin: 16px 0 0;
    color: var(--color-white);
  }
  h1 em { font-style: normal; color: var(--color-blue-tint); }
  .lede {
    margin: 24px 0 30px;
    font-size: var(--text-h3);
    line-height: 1.5;
    font-weight: 300;
    color: color-mix(in srgb, var(--color-white) 86%, transparent);
    max-width: 46ch;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .wm {
    position: absolute; z-index: 1; right: 24px; bottom: 20px;
    display: inline-flex; align-items: center; gap: 7px;
    color: var(--color-white); font-weight: 700; letter-spacing: -0.02em;
    font-size: 17px; text-shadow: 0 1px 10px color-mix(in srgb, var(--color-ink) 45%, transparent);
  }

  h2 { font-size: var(--text-h1); line-height: var(--text-h1--line-height); margin: 12px 0 0; max-width: 20ch; }

  /* WHAT YOU GET */
  .get-head h2 { max-width: 26ch; }
  .gets { margin-top: 40px; display: grid; gap: 20px; }
  .get { border-top: 2px solid var(--color-signal); padding-top: 18px; }
  .get .gn { font-family: var(--font-mono); font-size: var(--text-eyebrow); color: var(--color-signal); letter-spacing: 0.14em; }
  .get h3 { margin: 8px 0 6px; font-size: var(--text-h3); }
  .get p { margin: 0; font-size: var(--text-small); color: var(--color-body); }
  @media (min-width: 640px) { .gets { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .gets { grid-template-columns: repeat(5, 1fr); } }

  /* WHY */
  .why h2 { max-width: 22ch; }
  .why-sub { margin-top: 20px; font-size: var(--text-h3); font-weight: 300; color: var(--color-body); }
  .values { margin-top: 48px; display: grid; gap: 20px; }
  .value { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 28px; }
  .value .vn { font-family: var(--font-mono); font-size: var(--text-eyebrow); color: var(--color-signal); }
  .value h3 { margin: 10px 0 8px; font-size: var(--text-h3); }
  .value p { color: var(--color-body); font-size: var(--text-small); margin: 0; }
  @media (min-width: 760px) { .values { grid-template-columns: repeat(3, 1fr); } }

  /* SEAM */
  .seam-bar {
    margin-top: 36px; display: grid; grid-template-columns: 20fr 80fr;
    border-radius: 14px; overflow: hidden; border: 1px solid var(--color-border);
  }
  .seam-bar > div { padding: 24px 22px; display: flex; flex-direction: column; gap: 6px; min-height: 116px; justify-content: center; }
  .seam-bar .human { background: var(--color-signal); color: var(--color-white); }
  .seam-bar .machine { background: var(--color-mist); color: var(--color-ink); }
  .seam-bar .pct { font-size: 30px; font-weight: 700; letter-spacing: -0.02em; }
  .seam-bar .lbl { font-size: var(--text-small); font-weight: 500; opacity: 0.92; }
  .machine .lbl { color: var(--color-body); }
  .seam-note { margin-top: 20px; color: var(--color-body); }
  @media (prefers-reduced-motion: no-preference) {
    .reveal-in .seam-bar .human { animation: mx-in-left var(--dur-soft) var(--ease-out-quiet) both; }
    .reveal-in .seam-bar .machine { animation: mx-in-right var(--dur-soft) var(--ease-out-quiet) both; }
    @keyframes mx-in-left {
      from { opacity: 0; transform: translateX(-14px); }
    }
    @keyframes mx-in-right {
      from { opacity: 0; transform: translateX(14px); }
    }
  }

  /* METHOD */
  .method-head .eyebrow { color: var(--color-blue-tint); }
  .method-head h2 .plus { color: var(--color-blue-tint); }
  .method-head p { margin-top: 16px; color: color-mix(in srgb, var(--color-white) 78%, transparent); }
  .phases { margin-top: 48px; display: grid; gap: 1px; background: color-mix(in srgb, var(--color-white) 12%, transparent); border: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent); border-radius: 14px; overflow: hidden; }
  .phase {
    background: var(--color-ink);
    padding: 28px;
    border: 1px solid transparent;
    transition:
      transform var(--dur-quick) var(--ease-out-quiet),
      border-color var(--dur-quick) var(--ease-out-quiet);
  }
  @media (prefers-reduced-motion: no-preference) {
    .phase:hover {
      transform: translateY(-3px);
      border-color: color-mix(in srgb, var(--color-blue-tint) 40%, transparent);
    }
  }
  .phase .pno { font-family: var(--font-mono); font-size: var(--text-eyebrow); color: var(--color-blue-tint); letter-spacing: 0.14em; }
  .phase h3 { margin: 10px 0 8px; font-size: var(--text-h3); color: var(--color-white); }
  .phase p { margin: 0; font-size: var(--text-small); color: color-mix(in srgb, var(--color-white) 70%, transparent); }
  .method-cta { margin-top: 40px; }
  @media (min-width: 760px) { .phases { grid-template-columns: repeat(4, 1fr); } }

  /* SPECIALISTS */
  .specs { margin-top: 40px; display: grid; gap: 20px; }
  .spec { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 28px; text-align: center; }
  .spec-mono { color: var(--color-signal); display: inline-flex; }
  .spec-name { margin-top: 12px; font-size: 26px; font-weight: 700; letter-spacing: -0.02em; }
  .spec-role { font-size: var(--text-small); color: var(--color-body); }
  .spec-desc { margin: 10px 0 0; font-size: var(--text-small); color: var(--color-body); }
  @media (min-width: 640px) { .specs { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .specs { grid-template-columns: repeat(4, 1fr); } }

  /* INSIDE MAXXIM */
  .inside-head p.measure { margin-top: 16px; color: var(--color-body); }
  .frames { margin-top: 48px; display: flex; flex-direction: column; gap: 32px; }
  .frame { margin: 0; }
  .frame figcaption { margin-top: 12px; font-size: var(--text-small); color: var(--color-caption); }
  .lift-frame { transition: transform var(--dur-quick) var(--ease-out-quiet), box-shadow var(--dur-quick) var(--ease-out-quiet); }
  @media (prefers-reduced-motion: no-preference) {
    .lift-frame:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 40px color-mix(in srgb, #000 45%, transparent);
    }
  }
  .frames-note { margin-top: 24px; font-size: 12px; color: var(--color-caption); }

  /* BRAIN */
  .brain-band { position: relative; overflow: hidden; background: var(--color-ink); }
  .brain-bg { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.5; }
  .brain-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .brain-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-ink) 92%, transparent) 0%, color-mix(in srgb, var(--color-ink) 55%, transparent) 70%, transparent 100%);
  }
  .brain-copy { position: relative; z-index: 1; padding-block: clamp(72px, 12vw, 140px); max-width: 56ch; }
  .brain-copy .eyebrow { color: var(--color-blue-tint); }
  .brain-copy h2 { max-width: 16ch; color: var(--color-white); }
  .brain-copy p.measure { margin-top: 18px; color: color-mix(in srgb, var(--color-white) 78%, transparent); }
  .brain-support { margin-top: 18px; font-family: var(--font-mono); font-size: var(--text-small); color: color-mix(in srgb, var(--color-white) 65%, transparent); }

  /* WORK */
  .work-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; margin-bottom: 40px; }
  .work-grid { display: grid; gap: 24px; }
  @media (min-width: 700px) { .work-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .work-grid { grid-template-columns: repeat(3, 1fr); } }

  /* CTA */
  .cta-band { position: relative; overflow: hidden; background: var(--color-ink); border-top: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent); }
  .cta-bg { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.38; }
  .cta-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cta-copy { position: relative; z-index: 1; padding-block: clamp(72px, 12vw, 140px); }
  .cta-copy h2 { max-width: 24ch; color: var(--color-white); }
  .cta-copy p { margin-top: 18px; color: color-mix(in srgb, var(--color-white) 78%, transparent); }
  .final-actions { margin-top: 30px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .cta-copy :global(.btn-ghost) { color: var(--color-blue-tint); }
</style>
