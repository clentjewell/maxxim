---
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Button from "@components/ui/Button.astro";
import Monogram from "@components/ui/Monogram.astro";
import FrameDashboard from "@components/frames/FrameDashboard.astro";
import FrameBrain from "@components/frames/FrameBrain.astro";
import { SPECIALISTS } from "@lib/site";

const chapters = [
  { id: "why", label: "01 Why" },
  { id: "method", label: "02 The method" },
  { id: "people", label: "03 The people" },
  { id: "product", label: "04 The product" },
];
---

<BaseLayout
  title="The Maxxim Guide"
  description="How a whole agency fits in a box: the method, the specialists, the studios — and the named human who signs off every gate."
>
  <!-- HERO -->
  <section class="hero">
    <picture class="hero-bg" aria-hidden="true">
      <source srcset="/images/mx-trust.webp" type="image/webp" />
      <img
        src="/images/mx-trust.jpg"
        width="1920"
        height="1080"
        alt=""
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="container hero-copy" data-reveal>
      <p class="eyebrow">The system, explained</p>
      <h1>The Maxxim Guide</h1>
      <p class="intro measure">How a whole agency fits in a box: the method, the specialists, the studios — and the named human who signs off every gate.</p>
      <nav class="chapters" aria-label="Guide chapters">
        {chapters.map((c) => (
          <a href={`#${c.id}`} class="chapter-pill">{c.label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- 01 WHY -->
  <Section id="why" class="chapter" rule>
    <span class="chapter-no" data-reveal>01</span>
    <h2 data-reveal>Why humans stay in the loop</h2>
    <blockquote class="pull-line" data-reveal><p>AI proposes; a named person decides.</p></blockquote>

    <div class="tiles" data-reveal>
      <div class="tile">
        <h3>Trust</h3>
        <p>A client trusts a person, not a model.</p>
      </div>
      <div class="tile">
        <h3>Taste</h3>
        <p>Knowing which of ten good options is the right one.</p>
      </div>
      <div class="tile">
        <h3>Judgement</h3>
        <p>What to say to a regulated client, when to push back, what matters now.</p>
      </div>
    </div>

    <details class="more" data-reveal>
      <summary>Read the full reasoning</summary>
      <p>Maxxim is built on a simple division of labour: let AI do what AI is good at, and keep humans doing what only humans can.</p>
      <p>AI is extraordinary at the mechanical, repeatable, scalable parts of marketing — researching, drafting, generating options, producing documents, building pages. That work used to eat the hours. Maxxim automates it, so it happens in minutes.</p>
      <p>But three things stay stubbornly human, and they are exactly what a client is really paying for. <strong>Trust</strong> — a client trusts a person, not a model. <strong>Taste</strong> — knowing which of ten good options is the right one. <strong>Judgement</strong> — what to say to a regulated client, when to push back, what matters now. This framing is drawn from the work of Nate B. Jones.</p>
      <p>So every part of Maxxim keeps a human at the controls. AI proposes; a named person decides. Nothing counts as done, and nothing publishes, until someone signs it off. The old line was good, fast or cheap — pick two. Maxxim is built to break that trade-off: pick three.</p>
      <h3>Why Maxxim is built this way</h3>
      <p>Maxxim builds only what it must. Where excellent foundations already exist — the AI models, the desktop environment they run in — Maxxim leans on them and spends its own effort on the thin layer that is genuinely its own. It is the philosophy Nvidia's Jensen Huang has often described: don't build what someone else already builds well.</p>
      <p>The second principle is the right tool for each job. Text and reasoning go to the strongest language model available. Logos are made as true vector artwork, so they scale from favicon to billboard without losing an edge. Photographic imagery goes to an engine that handles conversational refinement. Video is animated from an approved still. Which engine sits behind each job changes as the field moves — and the system is built to swap them without anyone noticing.</p>
      <p>Finally, Maxxim absorbs the fiddly parts — hosting, publishing, scheduling — so running a roster of clients stays manageable for a small human team.</p>
    </details>
  </Section>

  <!-- 02 THE METHOD -->
  <Section id="method" class="chapter" tone="mist">
    <span class="chapter-no" data-reveal>02</span>
    <h2 data-reveal>The 3D method, gated</h2>

    <div class="gate-strip" data-reveal>
      <span class="gate-pill">Discover</span>
      <span class="gate-arrow" aria-hidden="true">→</span>
      <span class="gate-tag">gate</span>
      <span class="gate-arrow" aria-hidden="true">→</span>
      <span class="gate-pill">Design</span>
      <span class="gate-arrow" aria-hidden="true">→</span>
      <span class="gate-tag">gate</span>
      <span class="gate-arrow" aria-hidden="true">→</span>
      <span class="gate-pill">Deploy</span>
      <span class="gate-arrow" aria-hidden="true">→</span>
      <span class="gate-tag">loop</span>
      <span class="gate-arrow" aria-hidden="true">→</span>
      <span class="gate-pill">Deepen</span>
    </div>
    <p class="measure gate-hook" data-reveal>This is the most important idea in the method: later work unlocks only as earlier work exists.</p>

    <div class="stat-chips" data-reveal>
      <div class="stat-chip"><span class="stat-n">26</span><span class="stat-l">deliverables per engagement</span></div>
      <div class="stat-chip"><span class="stat-n">3</span><span class="stat-l">gated phases</span></div>
      <div class="stat-chip"><span class="stat-n">1</span><span class="stat-l">sign-off at every gate</span></div>
    </div>

    <details class="more" data-reveal>
      <summary>How gating works in detail</summary>
      <h3>The 3D method</h3>
      <p>Every engagement runs through three phases, in order.</p>
      <ol class="g-list">
        <li><strong>Discover</strong> — gather the raw intelligence: who the customer is, who the competitors are, what the offer really is. Nothing downstream is reliable until this is right, so Discover comes first and is reviewed before anything moves.</li>
        <li><strong>Design</strong> — turn insight into strategy: the customer profile, brand strategy, the plans, and the creative briefs. The heavy-lifting phase.</li>
        <li><strong>Deploy</strong> — produce the in-market activation work: the operational briefs and plans that take the brand to market.</li>
      </ol>
      <p>Each deliverable is a self-contained document. When one is produced it appears in the client's pipeline as <strong>Pending</strong> — drafted, but not yet counted. Only when a named human reviews and approves it does it become <strong>Approved</strong>. Progress is measured in approvals, not drafts. That is the discipline of the whole system: the work moves at AI speed, and the score is kept by people.</p>
      <h3>The deliverable catalogue</h3>
      <p>A finished engagement is a set of twenty-six documents, built up phase by phase.</p>
      <ul class="g-list">
        <li><strong>Discover (4):</strong> an audience teardown, a competitor analysis, an offer worksheet, and a one-page Discover summary for sign-off.</li>
        <li><strong>Design (10):</strong> the customer profile, brand strategy and logo brief; the business, marketing, social and website plans; brand guidelines and a copy deck; and a strategy summary that distils the phase.</li>
        <li><strong>Deploy (12):</strong> the execution layer — design, website and photo-and-video briefs, then SEO, paid media, email, CRM, PR, events and traditional media plans, an integrated communications summary, and a case study.</li>
      </ul>
      <p>Each phase ends with a single summary document, so sign-off is always a one-page decision, not a stack of paper.</p>
      <h3>How gating works</h3>
      <p>This is the most important idea in the method: later work unlocks only as earlier work exists. The creative studios will not make an asset until the document it depends on has actually been produced and saved for that client.</p>
      <p>A logo cannot be generated until its logo brief exists. Brand imagery waits for the brand guidelines. Everyday collateral — business cards, letterheads, email signatures — waits for the guidelines <em>and</em> a formally locked logo. Campaign pieces wait for the design brief. The Social Studio stays locked until the social strategy is written.</p>
      <p>This is not a nuisance; it is what keeps a brand consistent. Every visual is built on a brief that already exists, and nothing carries a logo that hasn't been signed off. When something is locked, the system says exactly why — and exactly what to produce first.</p>
    </details>
  </Section>

  <!-- 03 THE PEOPLE -->
  <Section id="people" class="chapter" rule>
    <span class="chapter-no" data-reveal>03</span>
    <h2 data-reveal>The specialists</h2>

    <div class="specs" data-reveal>
      {SPECIALISTS.map((s) => (
        <div class="spec">
          <span class="spec-mono"><Monogram size={22} /></span>
          <div class="spec-name">{s.name}</div>
          <div class="spec-role">{s.role}</div>
          <p class="spec-desc">{s.desc}</p>
        </div>
      ))}
    </div>

    <details class="more" data-reveal>
      <summary>More about the advisor panel</summary>
      <p>Four names front the system.</p>
      <ul class="g-list">
        <li><strong>Max</strong> — the AI partner. Runs the engagement and does the words: strategy, plans, copy, briefs, summaries. Max's name is a process: Map, Assemble, eXecute.</li>
        <li><strong>Sal</strong> — the designer, in the Design Studio. Makes the pixels. Sal's name is the process: Start, Adapt, Lock.</li>
        <li><strong>Pip</strong> — the social media manager, in the Social Studio. Pip's name is the process too: Prepare, Inspect, Post.</li>
        <li><strong>Ari</strong> — the Brain. Answers anything about a client, grounded in every document held for them.</li>
      </ul>
      <p>Behind the names sits a roster of forty-three focused specialists. <strong>Makers</strong> each produce one deliverable — the audience analyser writes the audience teardown, the brand strategist writes the brand strategy. <strong>Advisors</strong> review rather than write: an expert panel spanning brand consistency, behavioural psychology, growth and conversion, accessibility, analytics, legal compliance and more, brought in to pressure-test the work before or after it is made.</p>
    </details>
  </Section>

  <!-- 04 THE PRODUCT -->
  <Section id="product" class="chapter" tone="mist">
    <span class="chapter-no" data-reveal>04</span>
    <h2 data-reveal>The dashboard, the studios, the portal</h2>
    <p class="measure product-intro" data-reveal>Maxxim has three surfaces, each with one job.</p>

    <figure class="frame" data-reveal>
      <FrameDashboard />
      <figcaption>The operator dashboard — every client, live progress and AI spend on one screen.</figcaption>
    </figure>

    <div class="studio-tiles" data-reveal>
      <div class="tile">
        <h3>Design Studio</h3>
        <p>The Design Studio is where a client's visuals get made — logos, brand imagery, collateral, video. The designer is Sal, directed in plain English and grounded in everything the client already has: their strategy, their brand, their briefs.</p>
      </div>
      <div class="tile">
        <h3>Social Studio</h3>
        <p>The Social Studio is where a client's social media gets made and published, run by Pip.</p>
      </div>
    </div>

    <figure class="frame" data-reveal>
      <FrameBrain />
      <figcaption>The client portal's Brain — Ari, grounded in every document the engagement holds.</figcaption>
    </figure>
    <p class="frames-note" data-reveal>Frames recreated from the live Maxxim dashboard.</p>

    <details class="more" data-reveal>
      <summary>The full product tour</summary>
      <ul class="g-list">
        <li><strong>The workspace.</strong> The team works by talking to Max — Maxxim's AI partner — inside a Cowork plugin. Max carries the method, drafts every document, and drives the tools. Everything it produces saves to one secure store, so the work is never trapped on one machine.</li>
        <li><strong>The dashboard.</strong> Where humans track each client across the process, review and approve deliverables, and run the two creative studios — Design and Social.</li>
        <li><strong>The client portal.</strong> A clean, read-only view where a client follows their own project: progress, documents, and their Brain.</li>
      </ul>
      <p>An engine runs quietly behind all three, handling the heavy lifting — image generation, website builds, publishing. Nobody touches it directly. The rule of thumb: Max does the words; the studios do the pixels and posts; the engine ships it all.</p>

      <h3>The Design Studio</h3>
      <p>The flow spells Sal's name. <strong>Start</strong> — choose what to make and describe it briefly; Sal expands the description using the client's brand and generates candidates to compare. <strong>Adapt</strong> — refine by plain instruction: bolder, add the wordmark, make a mono version. Versions stack, and any earlier one can be branched from. <strong>Lock</strong> — turn the approved mark into production-ready vector files, ready for anything from a favicon to print.</p>
      <p>The Studio honours the gates: each asset type stays locked until its brief exists, and a human picks and approves every result. Sal generates; a person chooses.</p>

      <h3>The Social Studio</h3>
      <p>The process is Pip's name: <strong>Prepare</strong> — Pip drafts on-brand posts from the client's social strategy, with a tailored caption per platform and an optional on-brand image. <strong>Inspect</strong> — a human reviews every draft, tweaks the wording or swaps the image. <strong>Post</strong> — only once approved does anything publish, sensibly spaced rather than fired all at once.</p>
      <p>Nothing goes out without sign-off. Editing an approved post returns it to draft, so a change can never sneak through unreviewed. Pip can also draft on a schedule — preparing the week ahead automatically — but the drafts always wait in the queue for a person. The AI keeps the channels fed; the human keeps them safe.</p>

      <h3>The client portal</h3>
      <p>Clients get a sign-in of their own — a clean, read-only view of exactly one thing: their project.</p>
      <ul class="g-list">
        <li><strong>Files</strong> — their workspace: the full 3D Process with a live progress bar, and every document produced for them, ready to open or download as a polished, branded PDF.</li>
        <li><strong>Brain</strong> — their business's private brain: a personal assistant, Ari, that answers questions about their business, grounded in their own project documents and nothing else.</li>
        <li><strong>Help</strong> — a short guide written for clients.</li>
      </ul>
      <p>The portal is deliberately calm. A deliverable reads as in progress until it is ready, then ready to view. Clients follow along in real time without wading through drafts or internal workings — and they only ever see their own work.</p>

      <h3>How client websites work</h3>
      <p>Maxxim builds, publishes and hosts each client's website, and every change is made by a person on the team — previewed privately, then promoted live. Clients follow along in their portal; they never need to touch hosting or code.</p>
      <p>Every site lives in one of two states. <strong>Locked</strong> is the default: a modern, component-based site that the team evolves conversationally — change a shared element once and it updates everywhere. <strong>Unlocked</strong> freezes the finished site into plain, hand-editable pages for quick copy fixes and image swaps. Unlocking is a deliberate, one-way step taken when a design is settled.</p>
      <p>The ownership story is simple. The domain is registered in the client's name. Branded email runs on it. The finished site is theirs — a real asset, live at their own address, not a rental inside someone else's platform.</p>
    </details>
  </Section>

  <!-- CLOSING CTA -->
  <Section rule>
    <div class="g-cta" data-reveal>
      <Button href="/method" variant="outline">Walk the method</Button>
      <Button href="/contact">Start a conversation</Button>
    </div>
  </Section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: min(70vh, 680px);
    background: var(--color-ink);
  }
  .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-ink) 88%, transparent) 0%, color-mix(in srgb, var(--color-ink) 62%, transparent) 55%, color-mix(in srgb, var(--color-ink) 30%, transparent) 100%);
  }
  .hero-scrim::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, var(--color-ink), transparent 30%);
  }
  .hero-copy {
    position: relative;
    z-index: 1;
    padding-block: clamp(64px, 13vh, 128px) clamp(40px, 8vh, 72px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }
  .hero-copy .eyebrow { color: var(--color-blue-tint); }
  .hero-copy h1 {
    font-size: var(--text-display);
    line-height: var(--text-display--line-height);
    font-weight: 600;
    max-width: 17ch;
    margin: 0;
    color: var(--color-white);
  }
  .hero-copy .intro {
    font-size: var(--text-h3);
    line-height: 1.5;
    font-weight: 300;
    color: color-mix(in srgb, var(--color-white) 86%, transparent);
    margin: 0;
  }
  .chapters { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 10px; }
  .chapter-pill {
    font-size: var(--text-small);
    font-weight: 600;
    padding: 9px 16px;
    border: 1px solid color-mix(in srgb, var(--color-white) 30%, transparent);
    border-radius: var(--radius-pill);
    color: var(--color-white);
    transition: all 0.2s var(--ease-out-quiet);
  }
  .chapter-pill:hover { border-color: var(--color-blue-tint); color: var(--color-blue-tint); }

  /* CHAPTERS shared */
  :global(.chapter) { scroll-margin-top: 90px; }
  .chapter-no {
    display: block;
    font-family: var(--font-mono);
    font-size: 40px;
    font-weight: 600;
    line-height: 1;
    color: var(--color-signal);
    margin-bottom: 12px;
  }
  h2 { font-size: var(--text-h1); line-height: var(--text-h1--line-height); margin: 0 0 20px; max-width: 24ch; }

  /* 01 WHY */
  .pull-line {
    margin: 0 0 40px;
    padding-left: 20px;
    border-left: 3px solid var(--color-signal);
    max-width: 40ch;
  }
  .pull-line p {
    margin: 0;
    font-size: var(--text-h3);
    font-weight: 300;
    font-style: normal;
    color: var(--color-ink);
  }
  .tiles, .studio-tiles { margin-bottom: 40px; display: grid; gap: 20px; }
  .tile { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 28px; }
  .tile h3 { margin: 0 0 8px; font-size: var(--text-h3); }
  .tile p { margin: 0; color: var(--color-body); font-size: var(--text-small); }
  @media (min-width: 760px) { .tiles { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 640px) { .studio-tiles { grid-template-columns: repeat(2, 1fr); } }

  /* 02 THE METHOD */
  .gate-strip { margin-top: 40px; display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
  .gate-pill {
    font-size: var(--text-small);
    font-weight: 600;
    padding: 10px 18px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-white);
    color: var(--color-ink);
  }
  .gate-tag { font-family: var(--font-mono); font-size: var(--text-eyebrow); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-signal); }
  .gate-arrow { font-family: var(--font-mono); color: var(--color-signal); font-size: 16px; }
  .gate-hook { margin-top: 20px; color: var(--color-body); }
  .stat-chips { margin-top: 32px; margin-bottom: 40px; display: grid; gap: 16px; }
  .stat-chip { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 18px 22px; }
  .stat-n { display: block; font-size: 26px; font-weight: 700; letter-spacing: -0.02em; color: var(--color-ink); }
  .stat-l { display: block; margin-top: 4px; font-size: var(--text-small); color: var(--color-body); }
  @media (min-width: 640px) { .stat-chips { grid-template-columns: repeat(3, 1fr); } }

  /* 03 THE PEOPLE */
  .specs { margin-bottom: 40px; display: grid; gap: 20px; }
  .spec { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 28px; text-align: center; }
  .spec-mono { color: var(--color-signal); display: inline-flex; }
  .spec-name { margin-top: 12px; font-size: 26px; font-weight: 700; letter-spacing: -0.02em; }
  .spec-role { font-size: var(--text-small); color: var(--color-body); }
  .spec-desc { margin: 10px 0 0; font-size: var(--text-small); color: var(--color-body); }
  @media (min-width: 640px) { .specs { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .specs { grid-template-columns: repeat(4, 1fr); } }

  /* 04 THE PRODUCT */
  .product-intro { margin-bottom: 40px; color: var(--color-body); }
  .frame { margin: 0 0 32px; }
  .frame figcaption { margin-top: 12px; font-size: var(--text-small); color: var(--color-caption); }
  .frames-note { margin: -8px 0 40px; font-size: 12px; color: var(--color-caption); }

  /* DETAILS DISCLOSURE */
  details.more {
    margin-top: 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 18px 22px;
    background: var(--color-white);
  }
  summary {
    cursor: pointer;
    font-weight: 600;
    font-size: var(--text-small);
    color: var(--color-signal);
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: " +"; }
  details[open] summary::after { content: " −"; }
  details.more p {
    max-width: var(--container-measure);
    margin: 16px 0 0;
    color: var(--color-body);
  }
  details.more h3 {
    margin: 28px 0 4px;
    font-size: var(--text-h3);
    color: var(--color-ink);
  }
  details.more .g-list { margin-top: 16px; }

  /* Bulleted / numbered lists inside disclosures */
  .g-list {
    margin: 0 0 16px;
    padding: 0;
    list-style: none;
    max-width: var(--container-measure);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .g-list li {
    position: relative;
    padding-left: 22px;
    font-size: var(--text-body);
    color: var(--color-body);
  }
  .g-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--color-signal);
    transform: rotate(45deg);
  }
  ol.g-list { counter-reset: step; }
  ol.g-list li::before {
    content: counter(step);
    counter-increment: step;
    top: 0;
    width: auto;
    height: auto;
    border-radius: 0;
    background: none;
    transform: none;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--color-signal);
    font-weight: 700;
  }

  .g-cta { display: flex; flex-wrap: wrap; gap: 14px; }
</style>
