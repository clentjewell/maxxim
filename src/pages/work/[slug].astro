---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/ui/Section.astro";
import Button from "@components/ui/Button.astro";
import { SITE } from "@lib/site";

export async function getStaticPaths() {
  const all = await getCollection("work", ({ data }) => !data.draft);
  return all.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const webp = (path: string) => path.replace(/\.jpe?g$/i, ".webp");

// Legacy 3-phase device. Superseded by `move` (Discover/Design/Deploy/Deepen)
// when a study defines it — kept here so older studies render unchanged.
const phases =
  d.solution && !d.move
    ? [
        { no: "01", t: "Discover", body: d.solution.discover },
        { no: "02", t: "Design", body: d.solution.design },
        { no: "03", t: "Deploy", body: d.solution.deploy },
      ]
    : [];

const moveTiles = d.move
  ? [
      { no: "01", t: "Discover", body: d.move.discover },
      { no: "02", t: "Design", body: d.move.design },
      { no: "03", t: "Deploy", body: d.move.deploy },
    ]
  : [];

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Work", item: `${SITE.url}/work` },
    { "@type": "ListItem", position: 3, name: d.client, item: new URL(`/work/${entry.id}`, SITE.url).href },
  ],
};
---

<BaseLayout title={d.client} description={d.summary} ogImage={d.heroImage ?? "/og/default.png"}>
  <article>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    <header class="hero">
      <div class="container inner" data-reveal>
        <a href="/work" class="back">← All work</a>
        <div class="meta">
          <span class="eyebrow">{d.category}</span>
          {d.status === "launched"
            ? <span class="badge live"><span class="dot" aria-hidden="true"></span>Launched</span>
            : <span class="badge prep">Case study</span>}
        </div>
        <h1>{d.client}</h1>
        {d.heroClaim && <p class="claim-line">{d.heroClaim}</p>}
        <p class="summary measure">{d.summary}</p>
        {d.liveUrl && (
          <div class="actions"><Button href={d.liveUrl} variant="outline" external>Visit the live site</Button></div>
        )}
      </div>
    </header>

    {d.heroImage && (
      <div class="container hero-img" data-reveal>
        <picture>
          <source srcset={webp(d.heroImage)} type="image/webp" />
          <img src={d.heroImage} alt={`${d.client} — brand imagery`} width="1200" height="620" decoding="async" />
        </picture>
      </div>
    )}

    {d.callouts && d.callouts.length > 0 ? (
      <Section>
        <div class="block" data-reveal><span class="eyebrow">The numbers behind the belief</span><h2 class="sr-only">The numbers behind the belief</h2></div>
        <div class="callouts" data-reveal>
          {d.callouts.map((k) => (
            <div class="callout">
              <span class="co-value">{k.value}</span>
              <h3 class="co-title">{k.title}</h3>
              <p class="co-line">{k.line}</p>
            </div>
          ))}
        </div>
      </Section>
    ) : (
      d.results.length > 0 && (
        <Section>
          <div class="results" data-reveal>
            {d.results.map((r) => (
              <div class="result">
                <div class="r-metric">{r.metric}</div>
                <div class="r-label">{r.label}</div>
              </div>
            ))}
          </div>
        </Section>
      )
    )}

    {d.needs && d.needs.length > 0 ? (
      <Section tone="mist">
        <div class="block" data-reveal>
          <span class="eyebrow">The brief, in their terms</span>
          {d.challenge && <p class="lead measure">{d.challenge}</p>}
        </div>
        <ol class="needs" data-reveal>
          {d.needs.map((n, i) => (
            <li><span class="need-n">{String(i + 1).padStart(2, "0")}</span>{n}</li>
          ))}
        </ol>
      </Section>
    ) : (
      d.challenge && (
        <Section tone="mist">
          <div class="block" data-reveal>
            <span class="eyebrow">The challenge</span>
            <p class="lead measure">{d.challenge}</p>
          </div>
        </Section>
      )
    )}

    {d.whatWeSaw && (
      <div class="saw-band">
        <div class="container" data-reveal>
          <span class="eyebrow">What we saw</span>
          <p class="saw-line measure">{d.whatWeSaw}</p>
        </div>
      </div>
    )}

    {moveTiles.length > 0 ? (
      <Section>
        <div class="block" data-reveal><span class="eyebrow">The method</span><h2>The move.</h2></div>
        <div class="phases">
          {moveTiles.map((p) => (
            <div class="phase lift" data-reveal>
              <span class="pno">{p.no}</span>
              <h3>{p.t}</h3>
              <p>{p.body}</p>
            </div>
          ))}
          <div class="phase phase-deepen lift" data-reveal>
            <span class="pno">04</span>
            <h3>Deepen</h3>
            <p>{d.move?.deepen}</p>
          </div>
        </div>
      </Section>
    ) : (
      phases.length > 0 && (
        <Section>
          <div class="block" data-reveal><span class="eyebrow">The method</span><h2>Run through 3D.</h2></div>
          <div class="phases">
            {phases.map((p) => (
              <div class="phase lift" data-reveal>
                <span class="pno">{p.no}</span>
                <h3>{p.t}</h3>
                <p>{p.body}</p>
              </div>
            ))}
          </div>
        </Section>
      )
    )}

    {d.whatShipped && d.whatShipped.length > 0 && (
      <Section tone="mist">
        <div class="block" data-reveal><span class="eyebrow">What shipped</span><h2>{d.status === "launched" ? "Finished, owned, handed over." : "Built, and ready to hand over."}</h2></div>
        <ul class="shipped" data-reveal>
          {d.whatShipped.map((s) => <li>{s}</li>)}
        </ul>
      </Section>
    )}

    {d.gallery && d.gallery.length > 0 && (
      <Section>
        <div class="gallery" data-reveal>
          {d.gallery.map((g) => (
            <figure class="g-item lift">
              <picture>
                <source srcset={webp(g.image)} type="image/webp" />
                <img src={g.image} alt={g.label} width="1600" height="1000" loading="lazy" decoding="async" />
              </picture>
              <figcaption>
                <span class="g-label">{g.label}</span>
                {g.note && <span class="g-note">{g.note}</span>}
              </figcaption>
            </figure>
          ))}
        </div>
      </Section>
    )}

    {d.evidence && d.evidence.length > 0 && (
      <Section tone="mist">
        <div class="block" data-reveal><span class="eyebrow">See the work</span><h2>Proof you can click.</h2></div>
        <div class="ev-grid" data-reveal>
          {d.evidence.map((e) => (
            <div class="ev-card lift">
              {e.image && (
                <div class="ev-media">
                  <picture>
                    <source srcset={webp(e.image)} type="image/webp" />
                    <img src={e.image} alt={e.label} width="1600" height="1000" loading="lazy" decoding="async" />
                  </picture>
                </div>
              )}
              <div class="ev-body">
                <span class="ev-disc">{e.discipline}</span>
                <h3 class="ev-title">{e.label}</h3>
                <p class="ev-note">{e.note}</p>
                {e.url && (
                  <Button href={e.url} variant="outline" external class="ev-btn">{e.buttonLabel ?? "View & open"}</Button>
                )}
              </div>
            </div>
          ))}
        </div>
      </Section>
    )}

    {d.takeout && (
      <Section tone="ink">
        <div class="takeout-block" data-reveal>
          <span class="eyebrow eyebrow-light">The takeout</span>
          <p class="takeout-line">{d.takeout}</p>
          {d.deepenClaim && <p class="deepen-claim">{d.deepenClaim}</p>}
        </div>
      </Section>
    )}

    {(d.services.length > 0 || d.sectors.length > 0) && (
      <Section tone="mist">
        <div class="tags" data-reveal>
          {d.services.length > 0 && (
            <div><span class="eyebrow">Services</span><ul>{d.services.map((s) => <li>{s}</li>)}</ul></div>
          )}
          {d.sectors.length > 0 && (
            <div><span class="eyebrow">Sectors</span><ul>{d.sectors.map((s) => <li>{s}</li>)}</ul></div>
          )}
        </div>
      </Section>
    )}

    <Section>
      <div class="body measure" data-reveal><Content /></div>
      {d.reflection && (
        <blockquote class="quote" data-reveal>
          <p>“{d.reflection.quote}”</p>
          <cite>{d.reflection.name} · {d.reflection.role}</cite>
        </blockquote>
      )}
    </Section>

    <Section tone="ink" rule>
      <div class="cta" data-reveal>
        <div class="cta-copy">
          {d.atGlance && (
            <p class="glance-line">
              {d.atGlance.audience && <>Audience: {d.atGlance.audience}</>}
              {d.atGlance.audience && d.atGlance.scope && <> · </>}
              {d.atGlance.scope && <>Scope: {d.atGlance.scope}</>}
            </p>
          )}
          <h2>Powered by Maxxim.</h2>
        </div>
        <div class="cta-actions">
          <Button href="/contact" variant="solid-invert">Start a conversation</Button>
          <Button href="/work" variant="ghost">More work</Button>
        </div>
      </div>
    </Section>
  </article>
</BaseLayout>

<style>
  .hero { padding-block: clamp(48px, 10vh, 96px) clamp(24px, 4vw, 40px); }
  .inner { display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }
  .back { font-size: var(--text-small); color: var(--color-body); }
  .back:hover { color: var(--color-signal); }
  .meta { display: flex; align-items: center; gap: 12px; }
  .badge { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; border-radius: var(--radius-pill); padding: 4px 9px; display: inline-flex; align-items: center; gap: 6px; }
  .badge.live { color: var(--color-signal); border: 1px solid color-mix(in srgb, var(--color-signal) 40%, transparent); }
  .badge.prep { color: var(--color-caption); border: 1px solid var(--color-border); }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-signal); }
  h1 { font-size: var(--text-display); line-height: var(--text-display--line-height); margin: 0; }
  .claim-line { font-size: var(--text-h1); font-weight: 600; line-height: 1.1; letter-spacing: -0.01em; max-width: 20ch; margin: 6px 0 0; color: var(--color-signal); }
  .summary { font-size: var(--text-h3); font-weight: 300; color: var(--color-body); margin: 4px 0 0; }
  .actions { margin-top: 12px; }
  .hero-img { margin-block: clamp(20px, 4vw, 40px); border-radius: 20px; overflow: hidden; }
  .hero-img img { width: 100%; height: clamp(240px, 40vw, 520px); object-fit: cover; display: block; }
  @media (prefers-reduced-motion: no-preference) {
    .hero-img img { animation: mx-kenburns 22s var(--ease-out-quiet) forwards; }
    @keyframes mx-kenburns {
      from { transform: scale(1); }
      to { transform: scale(1.07); }
    }
  }

  .results { display: grid; gap: 24px; }
  .result { border-left: 2px solid var(--color-signal); padding-left: 20px; }
  .r-metric { font-size: clamp(2rem, 1rem + 4vw, 3rem); font-weight: 700; letter-spacing: -0.03em; }
  .r-label { font-size: var(--text-small); color: var(--color-body); }
  @media (min-width: 700px) { .results { grid-template-columns: repeat(3, 1fr); } }

  /* Call-outs: the supporting proof points, tiled. */
  .callouts { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 32px; }
  .callout { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 26px; }
  .co-value { font-family: var(--font-mono); font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2rem); font-weight: 500; color: var(--color-signal); letter-spacing: -0.01em; }
  .co-title { font-size: var(--text-h3); margin: 14px 0 6px; }
  .co-line { margin: 0; font-size: var(--text-small); line-height: 1.55; color: var(--color-body); }
  @media (min-width: 640px) { .callouts { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .callouts { grid-template-columns: repeat(4, 1fr); } }

  .block .eyebrow { display: block; margin-bottom: 12px; }
  .block h2 { font-size: var(--text-h1); margin: 0; }
  .lead { font-size: var(--text-h3); font-weight: 300; color: var(--color-body); margin: 0; }

  /* The brief: numbered needs, plain and legible. */
  .needs { list-style: none; margin: 32px 0 0; padding: 0; display: grid; gap: 20px; }
  .needs li { display: flex; gap: 16px; align-items: baseline; font-size: var(--text-h3); font-weight: 300; line-height: 1.4; padding-bottom: 20px; border-bottom: 1px solid var(--color-border); }
  .needs li:last-child { border-bottom: 0; padding-bottom: 0; }
  .need-n { font-family: var(--font-mono); font-size: var(--text-small); font-weight: 600; color: var(--color-signal); flex-shrink: 0; }
  @media (min-width: 800px) { .needs { grid-template-columns: repeat(3, 1fr); } .needs li { border-bottom: 0; padding-bottom: 0; } }

  /* What we saw: full-width statement band, mist bleeding to white. */
  .saw-band { padding-block: clamp(56px, 9vw, 100px); background: linear-gradient(180deg, var(--color-mist), var(--color-white)); }
  .saw-line { font-size: var(--text-h2); font-weight: 300; line-height: 1.3; margin: 14px 0 0; }

  .phases { margin-top: 40px; display: grid; gap: 24px; }
  .phase { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 28px; }
  .phase .pno { font-family: var(--font-mono); font-size: var(--text-eyebrow); color: var(--color-signal); letter-spacing: 0.14em; }
  .phase h3 { margin: 10px 0 8px; }
  .phase p { margin: 0; font-size: var(--text-small); color: var(--color-body); }
  .phase-deepen { border-left: 3px solid var(--color-signal); }
  @media (min-width: 800px) { .phases { grid-template-columns: repeat(3, 1fr); } .phase-deepen { grid-column: 1 / -1; } }
  @media (min-width: 1040px) { .phases { grid-template-columns: repeat(4, 1fr); } .phase-deepen { grid-column: auto; } }

  /* What shipped: pixel-diamond checklist, two columns wide. */
  .shipped { list-style: none; margin: 32px 0 0; padding: 0; display: grid; gap: 14px; }
  .shipped li { position: relative; padding-left: 24px; font-size: var(--text-body); color: var(--color-body); }
  .shipped li::before { content: ""; position: absolute; left: 0; top: 9px; width: 8px; height: 8px; border-radius: 2px; background: var(--color-signal); transform: rotate(45deg); }
  @media (min-width: 640px) { .shipped { grid-template-columns: repeat(2, 1fr); column-gap: 32px; } }

  /* Gallery */
  .gallery { display: grid; grid-template-columns: 1fr; gap: 24px; }
  .g-item { margin: 0; border-radius: var(--radius-card); overflow: hidden; border: 1px solid var(--color-border); background: var(--color-white); }
  .g-item picture, .g-item img { display: block; width: 100%; aspect-ratio: 16 / 10; object-fit: cover; }
  .g-item figcaption { display: flex; flex-direction: column; gap: 2px; padding: 16px 18px; }
  .g-label { font-size: var(--text-small); font-weight: 600; }
  .g-note { font-size: var(--text-small); color: var(--color-caption); }
  @media (min-width: 700px) { .gallery { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .gallery { grid-template-columns: repeat(3, 1fr); } }

  /* Evidence */
  .ev-grid { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 32px; }
  .ev-card { display: flex; flex-direction: column; background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-card); overflow: hidden; }
  .ev-media, .ev-media picture, .ev-media img { display: block; width: 100%; }
  .ev-media { aspect-ratio: 16 / 10; overflow: hidden; }
  .ev-media img { height: 100%; object-fit: cover; }
  .ev-body { display: flex; flex-direction: column; gap: 8px; padding: 24px; flex: 1; }
  .ev-disc { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-signal); }
  .ev-title { font-size: var(--text-h3); margin: 0; }
  .ev-note { font-size: var(--text-small); color: var(--color-body); margin: 0; flex: 1; }
  .ev-btn { align-self: flex-start; margin-top: 6px; }
  @media (min-width: 640px) { .ev-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .ev-grid { grid-template-columns: repeat(3, 1fr); } }

  /* Takeout */
  .takeout-block { max-width: 60ch; }
  .eyebrow-light { color: var(--color-blue-tint); }
  .takeout-line { font-size: var(--text-h2); font-weight: 300; line-height: 1.3; margin: 14px 0 0; }
  .deepen-claim { font-family: var(--font-mono); font-size: var(--text-small); color: var(--color-blue-tint); margin: 20px 0 0; }

  .tags { display: grid; gap: 32px; }
  .tags .eyebrow { display: block; margin-bottom: 12px; }
  .tags ul { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .tags li { font-size: var(--text-small); background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-pill); padding: 6px 13px; }
  @media (min-width: 640px) { .tags { grid-template-columns: 1fr 1fr; } }

  .body :global(p) { font-size: var(--text-body); color: var(--color-body); margin: 0 0 16px; }
  .quote { margin: 40px 0 0; border-top: 1px solid var(--color-border); padding-top: 28px; }
  .quote p { font-size: var(--text-h2); font-weight: 300; letter-spacing: -0.01em; max-width: 24ch; }
  .quote cite { display: block; margin-top: 14px; font-style: normal; font-size: var(--text-small); color: var(--color-caption); }

  .cta { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
  .cta-copy h2 { font-size: var(--text-h1); margin: 0; }
  .glance-line { font-family: var(--font-mono); font-size: var(--text-small); color: var(--color-blue-tint); margin: 0 0 10px; }
  .cta-actions { display: flex; gap: 14px; align-items: center; }
  .cta :global(.btn-ghost) { color: var(--color-blue-tint); }
</style>
