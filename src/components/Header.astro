---
import { NAV, CTA, SITE } from "@lib/site";
import Monogram from "@components/ui/Monogram.astro";
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label={`${SITE.brandName} home`}>
      <Monogram size={26} />
      <span class="brand-name">{SITE.brandName}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        NAV.map((item) => (
          <a href={item.href} class:list={["nav-link", isActive(item.href) && "is-active"]}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="actions">
      <a href={CTA.href} class="cta">{CTA.label}</a>
      <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false" data-menu-toggle>
        <span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" data-mobile-nav hidden>
    {NAV.map((item) => <a href={item.href} class="mobile-link">{item.label}</a>)}
    <a href={CTA.href} class="mobile-link mobile-cta">{CTA.label}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-white) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(12px);
    border-bottom: 1px solid var(--color-border-soft);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: 24px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--color-signal);
    flex: none;
  }
  .brand-name {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }
  .nav {
    display: none;
    gap: 32px;
    margin-inline: auto;
  }
  .nav-link {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-body);
    transition: color 0.2s var(--ease-out-quiet);
  }
  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-ink);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: none;
  }
  .cta {
    display: none;
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-white);
    background: var(--color-signal);
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    transition: filter 0.2s var(--ease-out-quiet);
  }
  .cta:hover {
    filter: brightness(1.08);
  }
  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    width: 16px;
    height: 1.5px;
    margin-inline: auto;
    background: var(--color-ink);
    transition: transform 0.2s var(--ease-out-quiet);
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 12px clamp(20px, 6vw, 64px) 24px;
    border-top: 1px solid var(--color-border-soft);
    gap: 4px;
  }
  .mobile-link {
    padding: 12px 0;
    font-size: var(--text-h3);
    font-weight: 500;
    border-bottom: 1px solid var(--color-border-soft);
  }
  .mobile-cta {
    color: var(--color-signal);
    border-bottom: none;
  }
  @media (min-width: 900px) {
    .nav { display: flex; }
    .cta { display: inline-flex; }
    .menu-toggle { display: none; }
    .mobile-nav { display: none !important; }
  }
</style>

<script>
  function initMenu() {
    const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
    if (!toggle || !nav) return;
    toggle.addEventListener("click", () => {
      const open = nav.hasAttribute("hidden");
      if (open) nav.removeAttribute("hidden");
      else nav.setAttribute("hidden", "");
      toggle.setAttribute("aria-expanded", String(open));
    });
  }
  initMenu();
  document.addEventListener("astro:page-load", initMenu);
</script>
