---
/**
 * The Maxxim mark — the pixel double-X. A cluster of 45°-rotated squares,
 * lifted straight from the wordmark. Main squares use currentColor (with
 * their original fill-opacity steps); the accent squares are fixed at the
 * brand's tint blue. No gradients, no shadows.
 * Geometry source of truth: site/build.mjs MONOGRAM().
 */
interface Props {
  size?: number;
  class?: string;
  title?: string;
}
const { size = 28, class: cls = "", title } = Astro.props;
---

